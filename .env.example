# Exemplo de arquivo .env
# Renomeie para .env e preencha com suas credenciais

DB_URL=jdbc:postgresql://localhost:5432/motorprodb
DB_USERNAME=postgres
DB_PASSWORD=***REMOVED***
DB_DDL_AUTO=none # ou update/create-drop para desenvolvimento

JWT_SECRET=sua_chave_secreta_jwt_aqui
JWT_EXPIRATION=86400000

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,file://,app://
